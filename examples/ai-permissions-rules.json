{
  "rules": [
    {
      "action": "block",
      "tool": "gmail.delete",
      "reason": "User: never auto-delete emails"
    },
    {
      "action": "block",
      "tool": "gmail.batchDelete",
      "reason": "User: never auto-delete emails"
    },
    {
      "action": "block",
      "tool": "exec",
      "argsPattern": "rm -rf|sudo|curl.*sh",
      "reason": "User: never dangerous commands"
    },
    {
      "action": "allow",
      "tool": "exec",
      "argsPattern": "^(ls|cat|head|tail|grep|pwd|which|file|echo|cd)",
      "reason": "User: read-only commands are safe"
    },
    {
      "action": "require_approval",
      "tool": "exec",
      "reason": "User: ask before running other commands"
    },
    {
      "action": "require_approval",
      "tool": "write",
      "reason": "User: ask before file changes"
    },
    {
      "action": "allow",
      "tool": "read",
      "reason": "User: safe read-only operations"
    },
    {
      "action": "allow",
      "tool": "gmail.list",
      "reason": "User: reading emails is fine"
    }
  ]
}
